value_bonus = 1.0
pierce_count = 1
net_radius = 60.0
net_max_catch = 5
catch_size_classes = Array[StringName]([&"small", &"medium"])
lure_pulse = 0
standing_wave = 0
tagging_net = 0
schooling_bonus = 0
upgrades = {
